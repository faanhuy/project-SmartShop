{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug React Frontend",
            "type": "msedge",
            "request": "attach",
            "port": 9222,
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/smartshop-frontend",
            "preLaunchTask": "launch-edge-debug",
            "timeout": 10000,
            "sourceMapPathOverrides": {
                "/@fs/*": "/*"
            }
        },
        {
            "name": "Launch SmartShop WebAPI",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-webapi",
            "program": "${workspaceFolder}/src/SmartShop.WebAPI/bin/Debug/net8.0/SmartShop.WebAPI.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/SmartShop.WebAPI",
            "launchSettingsProfile": "https",
            "stopAtEntry": false,
            "justMyCode": true,
            "exceptionOptions": [
                {
                    "exceptionFilter": "all",
                    "breakMode": "never"
                }
            ],
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ],
    "compounds": [
        {
            "name": "Run Full Stack (BE + FE)",
            "configurations": ["Launch SmartShop WebAPI", "Debug React Frontend"],
            "preLaunchTask": "start-react",
            "stopAll": true
        }
    ]
}
